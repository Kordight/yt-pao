# Copy to .env and edit values as needed
# Database (use DB_HOST=db to use the included MySQL container)
# If your MySQL runs on the host machine, use host.docker.internal on Docker Desktop/Windows
# or the host IP / DNS name of the external server.
DB_HOST=db
DB_PORT=3306
DB_USER=yt-pao
DB_PASSWORD=password
DB_NAME=yt_pao_db

# MySQL root password for the bundled container (if used)
MYSQL_ROOT_PASSWORD=rootpassword

# Frontend: base URL for API used by Vite-built app
VITE_API_BASE_URL=http://localhost:8001
